        "scaler = MinMaxScaler() # 이제부터 저걸 스케일러라고 부를 거임\n",
        "\n",
        "x_train = scaler.fit_transform(x_train) # 기준(fit)도 잡고 변신도\n",
        "x_test = scaler.transform(x_test) # 공부할 때 기준대로 변신만 (기준 잡으면 안 됨.)\n",
        "# scaler.fit 하는 순간 x_train의 min max가 스케일러 내부 메모리에 값이 저장\n",
        "\n",
        "# --- 4. 데이터 타입 변경하기 vvv\n",
        "# 독립 변수: 영향을 받지 않지만 종속변수에 영향을 주는 원인\n",
        "\n",
        "x_train = tf.cast(x_train, tf.float32)\n",
        "x_test = tf.cast(x_test, tf.float32)\n",
        "\n",
        "y_train = y_train.astype(bool)\n",
        "y_test = y_test.astype(bool)\n",
        "\n",
        "\n",
        "# --- 5. 정상/비정상 데이터 시각화\n",
        "\n",
        "normal_x_train = x_train[y_train]\n",
        "\n",
        "# fig, ax = plt.subplots(ncols=3, nrows=2, figsize=(9,6)) # 캔버스먼저\n",
        "# fig.suptitle(\"Normal ECG\")\n",
        "\n",
