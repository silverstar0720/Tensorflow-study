        "# plt.show()\n",
        "\n",
        "# ---\n",
        "\n",
        "anomalous_x_train = x_train[~y_train]\n",
        "\n",
        "# fig, ax = plt.subplots(ncols=3, nrows=2, figsize=(9,6))\n",
        "# fig.suptitle(\"Anomalous ECG\")\n",
        "\n",
        "# ax = ax.ravel()\n",
        "\n",
        "# for idx, ax in enumerate(ax):\n",
        "  # ax.grid()\n",
