        "\n",
        "# --- 모델 생성\n",
        "\n",
        "model = tf.keras.Sequential([\n",
        "    layers.LSTM(100, return_sequences=True, input_shape=(x_train_ex.shape[1], x_train_ex.shape[2])),\n",
