        "# ---\n",
        "\n",
        "import numpy as np    # 숫자 계산 천재입니다.\n",
        "import pandas as pd   # 표를 잘 읽고 써요.\n",
        "import tensorflow as tf   # ai를 실제로 만들어주는 가장 큰 공장장\n",
