        "from sklearn.preprocessing import MinMaxScaler # 0에서 1사이로 깎아줘.\n",
        "\n",
        "from tensorflow.keras import layers # 레고 블록..\n",
        "from tensorflow.keras.models import Model\n",
        "from sklearn.metrics import accuracy_score, precision_score, recall_score\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "import os\n",
        "\n",
        "# --- 1. gpu 기본 설정\n",
        "\n",
        "os.environ[\"CUDA_VISIBLE_DEVICE\"]=\"0\"\n",
        "gpus = tf.config.experimental.list_physical_devices('GPU')\n",
        "if gpus:\n",
        "  try:\n",
        "    tf.config.experimental.set_memory_growth(gpus[0], True)\n",
        "  except RuntimeError as e:\n",
        "    print(e)\n",
        "\n",
        "# --- 2. 데이터 파일 읽게 시키기\n",
        "\n",
        "data = pd.read_csv('http://storage.googleapis.com/download.tensorflow.org/data/ecg.csv', header=None)\n",
        "# data.head()\n",
        "\n",
        "X = data.values[:, :-1]\n",
        "Y = data.values[:, -1] # 답 클래스\n",
        "# print('X shape:', X.shape)\n",
        "# print(\"Y shape:\", Y.shape)\n",
        "\n",
        "# ---\n",
        "\n",
        "x_train, x_test, y_train, y_test = train_test_split(X, Y, test_size=0.2, random_state=7, stratify=Y)\n",
        "# print('Train shape:', x_train.shape) # 모양만 체크\n",
        "# print('Test shape:', x_test.shape)\n",
        "\n",
        "# from collections import Counter\n",
        "# print(Counter(y_train))\n",
